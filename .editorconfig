# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Universal settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files - 4 space indentation (PEP 8)
[*.py]
indent_style = space
indent_size = 4

# Web and config files - 2 space indentation
[*.{js,ts,jsx,tsx,json,yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files - preserve trailing whitespace
# (trailing whitespace is significant in Markdown for line breaks)
[*.md]
trim_trailing_whitespace = false
