# ========================================
# Novel Studio - Environment variable template
# ========================================
# Copy this file to `.env.local` (project root) or load via direnv/docker
# and fill in real secrets. All variables use the prefixes defined in
# src/shared/infrastructure/config/settings.py:
#   APP_*, DB_*, API_*, SECURITY_*, LLM_*, LOG_*, MONITORING_*, HEALTH_*
#
# Validation:
#   uv run python -c "from src.shared.infrastructure.config.settings import NovelEngineSettings; NovelEngineSettings()"
# ========================================

# ========================================
# Application (APP_*)
# ========================================

# Runtime environment: development | testing | staging | production
APP_ENVIRONMENT=development

# Enable debug mode (do not enable in production)
# APP_DEBUG=false

# Project metadata (optional overrides)
# APP_PROJECT_NAME=Novel Studio
# APP_PROJECT_VERSION=0.3.0
# APP_PROJECT_DESCRIPTION=Self-hosted single-author novel writing studio

# Project paths (optional overrides, defaults are relative to project root)
# APP_BASE_DIR=/app
# APP_CONFIG_DIR=/app/config
# APP_DATA_DIR=./data
# APP_LOGS_DIR=./logs

# ========================================
# Database (DB_*)
# ========================================

# Self-hosted SQLite connection URL (required; must start with sqlite:///)
DB_URL=sqlite:///./data/novel-engine.sqlite3

# Connection pool tuning
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_ECHO=false

# ========================================
# API server (API_*)
# ========================================

# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=1
# API_RELOAD=false
# API_TITLE=Novel Studio API
# API_DOCS_URL=/docs
# API_REDOC_URL=/redoc
# API_OPENAPI_URL=/openapi.json

# ========================================
# Security (SECURITY_*)
# ========================================

# Local session secret. Required outside testing; must be >= 16 characters.
# In production it MUST differ from the default.
SECURITY_SECRET_KEY=change-me-to-a-long-random-local-secret

# Allowed CORS origins (comma-separated). Keep restrictive in production.
SECURITY_CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8000,http://127.0.0.1:8000

# SECURITY_CORS_ALLOW_CREDENTIALS=true
# SECURITY_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
# SECURITY_CORS_ALLOW_HEADERS=Content-Type,Authorization,X-API-Key,X-Request-ID,Accept,Origin,X-Requested-With,X-CSRF-Token

# Rate limiting
# SECURITY_RATE_LIMIT=100/minute
# SECURITY_RATE_LIMIT_BURST=10

# ========================================
# LLM provider (LLM_*)
# ========================================

# Provider: mock | dashscope | openai_compatible
LLM_PROVIDER=mock

# Default model name
LLM_MODEL=studio-copilot-v1

# OpenAI-compatible provider credentials
# (also accepts OPENAI_API_KEY / OPENAI_API_BASE as aliases)
# LLM_API_KEY=your-openai-api-key-here
# LLM_API_BASE=https://api.openai.com

# DashScope (通义千问) credentials
# DASHSCOPE_API_KEY=your-dashscope-api-key-here
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com
# DASHSCOPE_MODEL=qwen3.5-flash
# DASHSCOPE_TRANSPORT_MODE=multimodal_generation
# DASHSCOPE_REVIEW_MODEL=qwen3.5-flash

# OpenAI-compatible model override
# OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# Request tuning
# LLM_TIMEOUT=30
# LLM_MAX_TOKENS=4096
# LLM_TEMPERATURE=0.7
# LLM_TOP_P=0.95
# LLM_TOP_K=40
# LLM_RETRY_ATTEMPTS=3
# LLM_RETRY_DELAY=1.0

# ========================================
# Logging (LOG_*)
# ========================================

# LOG_LEVEL=INFO
# LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_JSON_FORMAT=false
# LOG_FILE_PATH=./logs/novel-studio.log
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5
# LOG_CONSOLE_OUTPUT=true
# LOG_STRUCTURED=true

# ========================================
# Monitoring / telemetry (MONITORING_*)
# ========================================

# MONITORING_ENABLED=true
# MONITORING_METRICS_ENABLED=true
# MONITORING_METRICS_PORT=9090
# MONITORING_METRICS_PATH=/metrics
# MONITORING_TRACING_ENABLED=false
# MONITORING_JAEGER_ENDPOINT=http://localhost:14268/api/traces
# MONITORING_SERVICE_NAME=novel-studio

# ========================================
# Health checks (HEALTH_*)
# ========================================

# HEALTH_TIMEOUT_SECONDS=5
# HEALTH_CACHE_CHECK_ENABLED=true
# HEALTH_EXTERNAL_SERVICES_CHECK_ENABLED=true
