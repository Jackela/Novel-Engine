[importlinter]
root_package = src
include_external_packages = True

[importlinter:contract:functional-core]
name = Functional Core Isolation
type = forbidden
source_modules =
    src.contexts.*.domain
    src.shared.domain
forbidden_modules =
    src.contexts.*.application
    src.contexts.*.infrastructure
    src.shared.infrastructure

[importlinter:contract:application-isolation]
name = Application Layer Isolation
type = forbidden
source_modules =
    src.contexts.*.application
forbidden_modules =
    src.contexts.*.infrastructure
    src.shared.infrastructure

[importlinter:contract:contexts-outside-apps]
name = Contexts Stay Out of Apps
type = forbidden
source_modules = src.contexts
forbidden_modules = src.apps

[importlinter:contract:shared-kernel]
name = Shared Kernel Access
type = forbidden
source_modules = src.shared
forbidden_modules = src.contexts.*

[importlinter:contract:interface-infrastructure-isolation]
name = Interface Layer Isolation
type = forbidden
source_modules =
    src.contexts.*.interface
forbidden_modules =
    src.contexts.*.infrastructure

[importlinter:contract:domain-application-interface-isolation]
name = Domain and Application Avoid Interface
type = forbidden
source_modules =
    src.contexts.*.domain
    src.contexts.*.application
    src.shared.domain
forbidden_modules =
    src.contexts.*.interface
    src.shared.interface
