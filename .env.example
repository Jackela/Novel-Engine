# ========================================
# Novel Engine - Environment Configuration
# ========================================
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# ========================================
# Core Application Settings
# ========================================

# Application environment: development, testing, staging, production
APP_ENVIRONMENT=development

# Enable debug mode (true/false)
APP_DEBUG=false

# Project name
APP_PROJECT_NAME=Novel Engine

# Project version
APP_PROJECT_VERSION=0.1.1

# ========================================
# Database Configuration
# ========================================

# Database connection URL
# Supports: sqlite:///path, postgresql://user:pass@host:port/db, postgresql+asyncpg://...
DB_URL=sqlite:///./novel_engine.db

# Connection pool size
DB_POOL_SIZE=5

# Max overflow connections
DB_MAX_OVERFLOW=10

# Pool timeout in seconds
DB_POOL_TIMEOUT=30

# Echo SQL statements (true/false)
DB_ECHO=false

# ========================================
# Redis Cache Configuration
# ========================================

# Redis server host
REDIS_HOST=localhost

# Redis server port
REDIS_PORT=6379

# Redis database number (0-15)
REDIS_DB=0

# Redis password (leave empty if not required)
# REDIS_PASSWORD=

# Use SSL connection (true/false)
REDIS_SSL=false

# Socket timeout in seconds
REDIS_SOCKET_TIMEOUT=5

# Socket connect timeout in seconds
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Health check interval in seconds
REDIS_HEALTH_CHECK_INTERVAL=30

# ========================================
# API Server Configuration
# ========================================

# API server host
API_HOST=0.0.0.0

# API server port
API_PORT=8000

# Number of worker processes
API_WORKERS=1

# Enable auto-reload (development only)
API_RELOAD=false

# API title
API_TITLE=Novel Engine API

# API version
API_VERSION=0.1.0

# Swagger UI URL (set to empty to disable)
API_DOCS_URL=/docs

# ReDoc URL (set to empty to disable)
API_REDOC_URL=/redoc

# OpenAPI schema URL (set to empty to disable)
API_OPENAPI_URL=/openapi.json

# ========================================
# Security Configuration
# ========================================

# Secret key for JWT signing (min 16 chars, change in production!)
SECURITY_SECRET_KEY=change-me-in-production-minimum-16-chars

# JWT algorithm
SECURITY_ALGORITHM=HS256

# Access token expiration in minutes
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration in days
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet encryption key for sensitive data
# Generate: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# SECURITY_ENCRYPTION_KEY=

# CORS allowed origins (comma-separated)
SECURITY_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Allow CORS credentials (true/false)
SECURITY_CORS_ALLOW_CREDENTIALS=true

# Allowed CORS methods (comma-separated)
SECURITY_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Allowed CORS headers (comma-separated, use * for all)
SECURITY_CORS_ALLOW_HEADERS=*

# Rate limit string (e.g., "100/minute", "1000/hour")
SECURITY_RATE_LIMIT=100/minute

# Rate limit burst
SECURITY_RATE_LIMIT_BURST=10

# ========================================
# LLM Provider Configuration
# ========================================

# LLM provider: gemini, openai, anthropic, mock
LLM_PROVIDER=gemini

# LLM model name
LLM_MODEL=gemini-pro

# LLM API key
# Get from: https://aistudio.google.com/app/apikey (Gemini)
# LLM_API_KEY=your_api_key_here

# Custom API base URL (optional)
# LLM_API_BASE=

# Request timeout in seconds
LLM_TIMEOUT=30

# Max tokens per request
LLM_MAX_TOKENS=4096

# Sampling temperature (0.0 - 2.0)
LLM_TEMPERATURE=0.7

# Top-p sampling (0.0 - 1.0)
LLM_TOP_P=0.95

# Top-k sampling (1 - 100)
LLM_TOP_K=40

# Number of retry attempts
LLM_RETRY_ATTEMPTS=3

# Retry delay in seconds
LLM_RETRY_DELAY=1.0

# Monthly cost limit in USD
LLM_MAX_MONTHLY_COST=10.0

# ========================================
# Logging Configuration
# ========================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format string
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Use JSON log format (true/false)
LOG_JSON_FORMAT=false

# Log file path (optional)
# LOG_FILE_PATH=./logs/app.log

# Max log file size in bytes
LOG_MAX_BYTES=10485760

# Number of backup log files
LOG_BACKUP_COUNT=5

# Output logs to console (true/false)
LOG_CONSOLE_OUTPUT=true

# Use structured logging (true/false)
LOG_STRUCTURED=true

# ========================================
# Monitoring Configuration
# ========================================

# Enable monitoring (true/false)
MONITORING_ENABLED=true

# Enable Prometheus metrics (true/false)
MONITORING_METRICS_ENABLED=true

# Metrics server port
MONITORING_METRICS_PORT=9090

# Metrics endpoint path
MONITORING_METRICS_PATH=/metrics

# Enable distributed tracing (true/false)
MONITORING_TRACING_ENABLED=false

# Jaeger collector endpoint (optional)
# MONITORING_JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Service name for tracing
MONITORING_SERVICE_NAME=novel-engine

# Service version
MONITORING_SERVICE_VERSION=0.1.1
