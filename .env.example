# Novel Studio local configuration
APP_ENVIRONMENT=development
APP_DATA_DIR=./data
DB_URL=sqlite:///./data/novel-engine.sqlite3

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# Required outside testing. Generate a unique value for each installation.
SECURITY_SECRET_KEY=change-me-to-a-long-random-local-secret
SECURITY_CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8000,http://127.0.0.1:8000

# AI provider. Defaults to 'mock' in Docker Compose when LLM_PROVIDER is unset.
LLM_PROVIDER=mock
LLM_MODEL=studio-copilot-v1
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen3.5-flash
# LLM_API_KEY=
# LLM_API_BASE=https://api.openai.com/v1
# OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

LOG_LEVEL=INFO
LOG_JSON_FORMAT=false
MONITORING_METRICS_ENABLED=false
