#!/usr/bin/env bash
#
# ci - Unified Local CI Entry Point
# ==================================
#
# One command to run all local CI checks.
# Automatically detects what to run based on changed files.
#
# Usage:
#   ./scripts/ci              # Run all checks
#   ./scripts/ci --fast       # Fast checks only (30s)
#   ./scripts/ci --changed    # Check only changed files
#   ./scripts/ci --staged     # Check only staged files
#   ./scripts/ci --backend    # Backend only
#   ./scripts/ci --frontend   # Frontend only
#   ./scripts/ci --full       # Full CI (including E2E)
#   ./scripts/ci --fix        # Auto-fix issues where possible
#   ./scripts/ci --help       # Show help
#
# Examples:
#   ./scripts/ci --fast                    # Quick check before commit
#   ./scripts/ci --changed --backend       # Check changed backend files
#   ./scripts/ci --staged --fix            # Fix staged files
#

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Print helpers
print_header() {
    echo -e "${BLUE}${BOLD}════════════════════════════════════════════════════════════${NC}"
    echo -e "${BLUE}${BOLD}  $1${NC}"
    echo -e "${BLUE}${BOLD}════════════════════════════════════════════════════════════${NC}"
}

print_success() { echo -e "${GREEN}✓ $1${NC}"; }
print_error() { echo -e "${RED}✗ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }
print_info() { echo -e "${BLUE}ℹ $1${NC}"; }

# Show help
show_help() {
    cat << 'EOF'
Novel Engine - Unified Local CI

USAGE:
    ./scripts/ci [OPTIONS] [SCOPE]

OPTIONS:
    --fast          Fast checks only (pyramid + markers + unit tests) ~30s
    --changed       Check only changed files (vs main)
    --staged        Check only staged files
    --full          Full CI including E2E tests ~5min
    --fix           Auto-fix issues where possible
    --watch         Watch mode (re-run on file changes)
    --ci            Simulate CI environment exactly
    --report        Generate detailed report
    --verbose       Verbose output
    --help          Show this help

SCOPE:
    --backend       Backend checks only
    --frontend      Frontend checks only
    --python        Python checks only (alias for --backend)
    --js            JavaScript/TypeScript checks only (alias for --frontend)

EXAMPLES:
    ./scripts/ci                          # Run all checks
    ./scripts/ci --fast                   # Quick check (recommended before commit)
    ./scripts/ci --changed                # Check what you've changed
    ./scripts/ci --staged --fix           # Fix staged files
    ./scripts/ci --backend --fast         # Fast backend checks
    ./scripts/ci --frontend               # Frontend checks only
    ./scripts/ci --full                   # Complete CI simulation

INTEGRATION:
    pre-commit:  This script is called by pre-commit hooks
    ACT:         Use 'make act-ci' for GitHub Actions simulation
    Makefile:    Use 'make ci-full' for Make-based workflow

EOF
}

# Detect changed files
detect_changed_files() {
    local against="${1:-HEAD}"
    
    # Get changed files
    if git rev-parse --verify "$against"^{commit} >/dev/null 2>&1; then
        git diff --name-only "$against"
    else
        # First commit or no history
        git ls-files
    fi
}

# Detect scope from changed files
detect_scope() {
    local files="$1"
    
    local has_backend=false
    local has_frontend=false
    
    if echo "$files" | grep -qE '^(src|tests|scripts)/.*\.py$'; then
        has_backend=true
    fi
    
    if echo "$files" | grep -qE '^frontend/'; then
        has_frontend=true
    fi
    
    if $has_backend && $has_frontend; then
        echo "both"
    elif $has_backend; then
        echo "backend"
    elif $has_frontend; then
        echo "frontend"
    else
        echo "both"  # Default to both if can't detect
    fi
}

# Run checks based on mode
run_fast() {
    print_header "FAST CI CHECK (~30s)"
    print_info "Running essential checks..."
    
    bash "$PROJECT_ROOT/scripts/ci-check.sh" --fast
}

run_full() {
    print_header "FULL CI CHECK (~5min)"
    print_info "Running complete CI simulation..."
    
    bash "$PROJECT_ROOT/scripts/ci-check.sh" --full
}

run_backend() {
    print_header "BACKEND CI CHECK"
    
    bash "$PROJECT_ROOT/scripts/ci-check.sh" --backend
}

run_frontend() {
    print_header "FRONTEND CI CHECK"
    
    bash "$PROJECT_ROOT/scripts/ci-check.sh" --frontend
}

run_changed() {
    local against="${1:-main}"
    
    print_header "CHANGED FILES CHECK"
    
    local files=$(detect_changed_files "$against")
    local scope=$(detect_scope "$files")
    
    print_info "Detected scope: $scope"
    print_info "Changed files:"
    echo "$files" | head -20
    
    case "$scope" in
        backend)
            run_backend
            ;;
        frontend)
            run_frontend
            ;;
        both)
            print_info "Running both backend and frontend checks..."
            run_backend || true
            run_frontend || true
            ;;
    esac
}

run_staged() {
    print_header "STAGED FILES CHECK"
    
    local files=$(git diff --cached --name-only)
    if [ -z "$files" ]; then
        print_warning "No staged files"
        exit 0
    fi
    
    local scope=$(detect_scope "$files")
    print_info "Detected scope: $scope"
    
    # Run pre-commit on staged files
    if command -v pre-commit &> /dev/null; then
        pre-commit run --files $files
    else
        print_warning "pre-commit not installed, running basic checks..."
        run_fast
    fi
}

run_fix() {
    print_header "AUTO-FIX MODE"
    
    print_info "Running auto-fixers..."
    
    # Python fixes
    if command -v ruff &> /dev/null; then
        print_info "Running Ruff fix..."
        ruff check src/ tests/ --fix || true
        ruff format src/ tests/ || true
    fi
    
    if command -v black &> /dev/null; then
        print_info "Running Black..."
        black src/ tests/ || true
    fi
    
    # Frontend fixes
    if [ -d "$PROJECT_ROOT/frontend" ]; then
        cd "$PROJECT_ROOT/frontend"
        if npm run format --silent 2>/dev/null; then
            print_info "Frontend formatted"
        fi
        cd "$PROJECT_ROOT"
    fi
    
    print_success "Auto-fix complete"
}

run_watch() {
    print_header "WATCH MODE"
    print_info "Re-running checks on file changes..."
    print_info "Press Ctrl+C to stop"
    
    if command -v ptw &> /dev/null; then
        ptw -- -m unit --tb=short
    else
        print_error "pytest-watch not installed. Run: pip install pytest-watch"
        exit 1
    fi
}

run_ci() {
    # Simulate exact CI environment
    print_header "CI SIMULATION"
    print_info "Running exact CI pipeline locally..."
    
    # Set CI environment variable
    export CI=true
    export GITHUB_ACTIONS=true
    
    run_full
}

# Main
declare -a ARGS=()
MODE=""
SCOPE=""
FIX=false
WATCH=false
REPORT=false
VERBOSE=false

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --fast)
            MODE="fast"
            shift
            ;;
        --full)
            MODE="full"
            shift
            ;;
        --changed)
            MODE="changed"
            shift
            ;;
        --staged)
            MODE="staged"
            shift
            ;;
        --backend|--python)
            SCOPE="backend"
            shift
            ;;
        --frontend|--js)
            SCOPE="frontend"
            shift
            ;;
        --fix)
            FIX=true
            shift
            ;;
        --watch)
            WATCH=true
            shift
            ;;
        --ci)
            MODE="ci"
            shift
            ;;
        --report)
            REPORT=true
            shift
            ;;
        --verbose|-v)
            VERBOSE=true
            shift
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Handle fix mode
if $FIX; then
    run_fix
    # Continue to run checks after fix
fi

# Handle watch mode
if $WATCH; then
    run_watch
    exit 0
fi

# Handle modes
case "$MODE" in
    fast)
        if [ -n "$SCOPE" ]; then
            case "$SCOPE" in
                backend) run_backend ;;
                frontend) run_frontend ;;
            esac
        else
            run_fast
        fi
        ;;
    full|ci)
        run_full
        ;;
    changed)
        run_changed "${ARGS[0]:-main}"
        ;;
    staged)
        run_staged
        ;;
    *)
        # Default mode based on scope
        if [ -n "$SCOPE" ]; then
            case "$SCOPE" in
                backend) run_backend ;;
                frontend) run_frontend ;;
            esac
        else
            # Default: run fast mode
            run_fast
        fi
        ;;
esac
