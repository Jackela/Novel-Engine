{
  "name": "storyforge-ai-frontend",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview --host 0.0.0.0 --port 4173",
    "test": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "test:unit": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "test:watch": "node ./node_modules/vitest/vitest.mjs --config vitest.config.ts",
    "test:ui": "node ./node_modules/vitest/vitest.mjs --config vitest.config.ts --ui",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts --coverage",
    "test:e2e": "node ./scripts/run-playwright.mjs test",
    "test:e2e:smoke": "node ./scripts/run-playwright.mjs test tests/e2e/frontend-smoke.spec.ts",
    "test:e2e:headed": "node ./scripts/run-playwright.mjs test --headed",
    "test:e2e:ui": "node ./scripts/run-playwright.mjs test --ui",
    "playwright:install": "node ./node_modules/playwright/cli.js install",
    "typecheck": "npm run type-check",
    "type-check": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "size-limit": [
    {
      "name": "Initial Bundle",
      "path": "dist/assets/index-*.js",
      "limit": "400 KB",
      "gzip": true
    },
    {
      "name": "Route Chunks",
      "path": "dist/assets/*-*.js",
      "limit": "200 KB",
      "gzip": true,
      "ignore": [
        "dist/assets/index-*.js",
        "dist/assets/vendor-*.js"
      ]
    }
  ],
  "dependencies": {
    "@dagrejs/dagre": "^2.0.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^1.9.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-router": "^1.151.6",
    "@tiptap/extension-mention": "^3.18.0",
    "@tiptap/extension-placeholder": "^3.18.0",
    "@tiptap/pm": "^3.18.0",
    "@tiptap/react": "^3.18.0",
    "@tiptap/starter-kit": "^3.18.0",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^2.30.0",
    "framer-motion": "^10.16.1",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.0",
    "lodash-es": "^4.17.21",
    "lucide-react": "^0.562.0",
    "markdown-it": "^14.1.0",
    "next-themes": "^0.4.6",
    "playwright": "^1.55.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^13.2.2",
    "react-query": "^3.39.3",
    "react-redux": "^8.1.2",
    "react-router-dom": "^6.15.0",
    "react-window": "^1.8.8",
    "react-window-infinite-loader": "^1.0.9",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.7.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "use-debounce": "^9.0.4",
    "web-vitals": "^4.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@axe-core/react": "^4.11.0",
    "@eslint/js": "^9.30.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^11.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.4",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.30.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^24.1.0",
    "msw": "^2.12.7",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "rollup": "^3.29.5",
    "size-limit": "^11.1.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.44.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.2",
    "vite": "8.0.2",
    "vitest": "^4.0.15",
    "yaml": "^2.8.2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
