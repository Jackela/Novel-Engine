{
  "name": "novel-engine-studio",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:ui": "vitest --config vitest.config.ts --ui",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:e2e": "node ./scripts/run-playwright.mjs test",
    "test:e2e:smoke": "node ./scripts/run-playwright.mjs test tests/e2e/studio.spec.ts",
    "test:e2e:full-audit": "node ./scripts/run-playwright.mjs test tests/e2e/studio.spec.ts",
    "test:e2e:headed": "node ./scripts/run-playwright.mjs test --headed",
    "test:e2e:ui": "node ./scripts/run-playwright.mjs test --ui",
    "playwright:install": "playwright install",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "type-check": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@fontsource-variable/geist": "^5.2.9",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.2",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  }
}
