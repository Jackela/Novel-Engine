# ACT Secrets Template
# Copy this file to .github/act-secrets and fill in your actual values
# Usage: cp .github/act-secrets.sample .github/act-secrets
#
# IMPORTANT: .github/act-secrets is in .gitignore and should NEVER be committed!

# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, workflow
GITHUB_TOKEN=your_github_token_here

# Codecov Token (optional, for coverage reporting)
# Get from: https://app.codecov.io/gh/your-username/novel-engine/settings
CODECOV_TOKEN=your_codecov_token_here

# Additional secrets can be added here as needed
# Format: KEY=value
